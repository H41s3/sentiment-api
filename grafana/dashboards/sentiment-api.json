{
  "title": "Sentiment API",
  "uid": "sentiment-api",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Inference Requests Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(sentiment_inference_requests_total[5m])) by (endpoint, label)",
          "legendFormat": "{{endpoint}} - {{label}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Inference Duration (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sentiment_inference_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sentiment_inference_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p95 {{endpoint}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(sentiment_inference_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p99 {{endpoint}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Batch Size (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sentiment_batch_size_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sentiment_batch_size_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (handler, status)",
          "legendFormat": "{{handler}} - {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Model Loaded",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "NOT LOADED", "color": "red" },
                "1": { "text": "LOADED", "color": "green" }
              }
            }
          ]
        },
        "overrides": []
      },
      "targets": [{ "expr": "sentiment_model_loaded", "refId": "A" }]
    },
    {
      "id": 8,
      "title": "Total Inferences",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(sentiment_inference_requests_total)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Input Text Length (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "chars" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sentiment_input_text_length_chars_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sentiment_input_text_length_chars_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx errors/s",
          "refId": "A"
        }
      ]
    }
  ]
}
