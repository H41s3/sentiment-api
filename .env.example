MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english
MAX_LENGTH=512
PORT=8000

# Optional: set to enforce API key on /analyze routes
# API_KEY=your-secret-key-here

# Optional: comma-separated allowed CORS origins (default: all)
# CORS_ORIGINS=https://yourapp.com,https://staging.yourapp.com

# Workers (used by gunicorn in production)
# WEB_CONCURRENCY=2
