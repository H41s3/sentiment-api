# Sentiment API — Environment Configuration
# Copy this file to .env and adjust values for your deployment.

# HuggingFace model identifier (default: distilbert-base-uncased-finetuned-sst-2-english)
MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english

# Maximum token length passed to the tokenizer (64–2048, default: 512)
MAX_LENGTH=512

# Server port (default: 8000)
PORT=8000

# API key for authentication. Leave unset to disable auth entirely.
# API_KEY=your-secret-key-here

# Comma-separated list of allowed CORS origins (default: *)
# CORS_ORIGINS=["https://your-frontend.com"]

# Number of gunicorn workers — each holds a copy of the model in memory (default: 2)
# WEB_CONCURRENCY=2

# Maximum texts per batch request (1–128, default: 32)
# MAX_BATCH_SIZE=32

# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# LOG_LEVEL=INFO
